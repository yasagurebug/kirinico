<Window x:Class="Kirinico.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Kirinico.App.Controls"
        xmlns:services="clr-namespace:Kirinico.App.Services"
        Title="{Binding WindowTitle}"
        Width="1680"
        Height="980"
        MinWidth="1380"
        MinHeight="860"
        Background="#101316"
        AllowDrop="True"
        PreviewDragOver="Window_OnPreviewDragOver"
        PreviewDrop="Window_OnPreviewDrop"
        PreviewMouseDown="Window_OnPreviewMouseDown"
        PreviewKeyDown="Window_OnPreviewKeyDown">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB" />
            <Setter Property="Foreground" Value="#101316" />
            <Setter Property="BorderBrush" Value="#A9B4C0" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#80374048" />
                    <Setter Property="BorderBrush" Value="#6B7783" />
                    <Setter Property="Foreground" Value="#D4DCE4" />
                    <Setter Property="Opacity" Value="0.7" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ToggleButton">
            <Setter Property="Background" Value="#E5E7EB" />
            <Setter Property="Foreground" Value="#101316" />
            <Setter Property="BorderBrush" Value="#A9B4C0" />
            <Setter Property="BorderThickness" Value="1" />
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#D7E7FB" />
                    <Setter Property="BorderBrush" Value="#79A4D8" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#80374048" />
                    <Setter Property="BorderBrush" Value="#6B7783" />
                    <Setter Property="Foreground" Value="#D4DCE4" />
                    <Setter Property="Opacity" Value="0.7" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style x:Key="ToolbarToggleStyle" TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="10,6" />
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="HorizontalContentAlignment" Value="Right" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <DataTemplate x:Key="ZoomPresetTemplate">
            <TextBlock VerticalAlignment="Center" Text="{Binding StringFormat={}{0}%}" />
        </DataTemplate>

        <Style x:Key="PanelGroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Foreground" Value="#E8EEF5" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </Window.Resources>

        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="10"
                Margin="0,0,0,12"
                Background="#171C22"
                BorderBrush="#2D3640"
                BorderThickness="1"
                CornerRadius="10">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButtonStyle}" Margin="18,0,0,0" Click="AboutButton_OnClick">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="20" Height="20" VerticalAlignment="Center" Source="{x:Static services:ToolbarIconService.AboutIcon}" />
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="About" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="OpenImageButton_OnClick">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="20" Height="20" VerticalAlignment="Center" Source="{x:Static services:ToolbarIconService.FileOpenIcon}" />
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="開く" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="SaveImageButton_OnClick">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="20" Height="20" VerticalAlignment="Center" Source="{x:Static services:ToolbarIconService.SaveIcon}" />
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="保存" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="ReprocessButton_OnClick">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="20" Height="20" VerticalAlignment="Center" Source="{x:Static services:ToolbarIconService.SyncIcon}" />
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="再処理" />
                        </StackPanel>
                    </Button>

                    <CheckBox Margin="0,0,18,0"
                              VerticalAlignment="Center"
                              Foreground="#E8EEF5"
                              Content="自動再処理"
                              IsChecked="{Binding AutoReprocess}" />

                    <CheckBox Margin="0,0,18,0"
                              VerticalAlignment="Center"
                              Foreground="#E8EEF5"
                              Content="高速プレビュー"
                              IsChecked="{Binding FastPreviewEnabled}" />

                    <ComboBox x:Name="ZoomComboBox"
                              Width="110"
                              Margin="0,0,18,0"
                              Padding="6,2"
                              FontSize="14"
                              VerticalContentAlignment="Center"
                              IsEditable="True"
                              IsTextSearchEnabled="False"
                              ItemsSource="{Binding ZoomPresetOptions}"
                              ItemTemplate="{StaticResource ZoomPresetTemplate}"
                              Text="{Binding ZoomPercentText, Mode=OneWay}"
                              SelectionChanged="ZoomComboBox_OnSelectionChanged"
                              LostKeyboardFocus="ZoomComboBox_OnLostKeyboardFocus"
                              PreviewKeyDown="ZoomComboBox_OnPreviewKeyDown" />

                    <Button Style="{StaticResource ToolbarButtonStyle}" Margin="18,0,8,0" Click="ExportSettingsButton_OnClick">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="20" Height="20" VerticalAlignment="Center" Source="{x:Static services:ToolbarIconService.ExportIcon}" />
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="設定エクスポート" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ToolbarButtonStyle}" Click="ImportSettingsButton_OnClick">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="20" Height="20" VerticalAlignment="Center" Source="{x:Static services:ToolbarIconService.ImportIcon}" />
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="設定インポート" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ToolbarButtonStyle}" Margin="18,0,8,0" Click="SaveRawAlphaButton_OnClick">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="20" Height="20" VerticalAlignment="Center" Source="{x:Static services:ToolbarIconService.SaveIcon}" />
                            <TextBlock Margin="8,0,0,0" VerticalAlignment="Center" Text="A_raw保存" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:ZoomPanImageViewer Grid.Row="0"
                                         Grid.Column="0"
                                         Margin="0,0,6,6"
                                         Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}"
                                         VerticalAlignment="Top"
                                         Title="元画像"
                                         Source="{Binding OriginalImage}"
                                         OverlaySource="{Binding OriginalEditOverlayImage}"
                                         ViewerBackground="{Binding OriginalViewerBackground}"
                                         ViewportState="{Binding SharedViewport}"
                                         LeftPanEnabled="{Binding EditableViewerPansWithLeftButton}"
                                         InteractionCursor="{Binding EditableViewerCursor}"
                                         PointerPressed="OriginalViewer_OnPointerPressed"
                                         PointerMoved="OriginalViewer_OnPointerMoved"
                                         PointerReleased="OriginalViewer_OnPointerReleased"
                                         PointerExited="Viewer_OnPointerExited" />

            <controls:ZoomPanImageViewer Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="6,0,6,6"
                                         Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}"
                                         VerticalAlignment="Top"
                                         Title="trimap"
                                         Source="{Binding TrimapImage}"
                                         ViewerBackground="{Binding OriginalViewerBackground}"
                                         ViewportState="{Binding SharedViewport}"
                                         LeftPanEnabled="{Binding EditableViewerPansWithLeftButton}"
                                         InteractionCursor="{Binding EditableViewerCursor}"
                                         PointerPressed="TrimapViewer_OnPointerPressed"
                                         PointerMoved="TrimapViewer_OnPointerMoved"
                                         PointerReleased="TrimapViewer_OnPointerReleased"
                                         PointerExited="Viewer_OnPointerExited" />

            <controls:ZoomPanImageViewer Grid.Row="0"
                                         Grid.Column="2"
                                         Margin="6,0,0,6"
                                         Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}"
                                         VerticalAlignment="Top"
                                         Title="{Binding ResultViewerTitle}"
                                         Source="{Binding DisplayedResultImage}"
                                         ViewerBackground="{Binding FinalViewerBackground}"
                                         ViewportState="{Binding SharedViewport}"
                                         CoordinateScaleX="{Binding DisplayedResultCoordinateScaleX}"
                                         CoordinateScaleY="{Binding DisplayedResultCoordinateScaleY}"
                                         LeftPanEnabled="{Binding ResultViewerPansWithLeftButton}"
                                         InteractionCursor="{Binding ResultViewerCursor}"
                                         PointerPressed="FinalViewer_OnPointerPressed"
                                         PointerMoved="FinalViewer_OnPointerMoved"
                                         PointerExited="Viewer_OnPointerExited"
                                         ViewerDoubleClicked="FinalViewer_OnDoubleClicked"
                                         TitleClicked="ResultViewer_OnTitleClicked" />

            <Border Grid.Row="1"
                    Grid.ColumnSpan="3"
                    Margin="0,6,0,0"
                    Padding="12"
                    Background="#171C22"
                    BorderBrush="#2D3640"
                    BorderThickness="1"
                    CornerRadius="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ScrollViewer Grid.Column="0"
                                  Margin="0,0,10,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="4">
                            <GroupBox Style="{StaticResource PanelGroupBoxStyle}" Header="背景指定">
                                <Grid Margin="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"
                                               Text="指定モード" />
                                    <ComboBox Grid.Row="0"
                                              Grid.Column="1"
                                              ItemsSource="{Binding BackgroundSpecificationModeOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedBackgroundSpecificationMode}" />

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Margin="0,10,10,0"
                                               VerticalAlignment="Center"
                                               Text="背景色" />
                                    <DockPanel Grid.Row="1"
                                               Grid.Column="1"
                                               Margin="0,10,0,8">
                                        <Button DockPanel.Dock="Right"
                                                Margin="0,0,6,0"
                                                Click="WandRemoveModeButton_OnClick"
                                                IsEnabled="{Binding IsManualSeedBackgroundMode}">
                                            <Image Width="18" Height="18" Source="{x:Static services:ToolbarIconService.WandRemoveIcon}" />
                                        </Button>
                                        <ToggleButton DockPanel.Dock="Right"
                                                      Margin="12,0,6,0"
                                                      IsChecked="{Binding IsWandAddMode, Mode=OneWay}"
                                                      Click="WandAddModeButton_OnClick"
                                                      IsEnabled="{Binding IsManualSeedBackgroundMode}">
                                            <Image Width="18" Height="18" Source="{x:Static services:ToolbarIconService.WandAddIcon}" />
                                        </ToggleButton>
                                        <ToggleButton DockPanel.Dock="Right"
                                                      Margin="0,0,6,0"
                                                      IsChecked="{Binding IsBackgroundColorEyedropperMode, Mode=OneWay}"
                                                      Click="BackgroundEyedropperModeButton_OnClick"
                                                      IsEnabled="{Binding IsColorRangeBackgroundMode}">
                                            <Image Width="18" Height="18" Source="{x:Static services:ToolbarIconService.DropperIcon}" />
                                        </ToggleButton>
                                        <Button DockPanel.Dock="Right"
                                                Click="BackgroundColorPickerButton_OnClick"
                                                IsEnabled="{Binding IsColorRangeBackgroundMode}">
                                            <Image Width="18" Height="18" Source="{x:Static services:ToolbarIconService.PaletteIcon}" />
                                        </Button>
                                        <Border DockPanel.Dock="Right"
                                                Width="24"
                                                Height="24"
                                                Margin="0,0,6,0"
                                                VerticalAlignment="Center"
                                                CornerRadius="2"
                                                BorderBrush="#5A6570"
                                                BorderThickness="1"
                                                Background="{Binding BackgroundColorPreviewBrush}"
                                                IsEnabled="{Binding IsColorRangeBackgroundMode}" />
                                        <TextBox Text="{Binding BackgroundColorHex, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource InputTextBoxStyle}"
                                                 IsEnabled="{Binding IsColorRangeBackgroundMode}" />
                                    </DockPanel>
                                </Grid>
                            </GroupBox>

                            <GroupBox Style="{StaticResource PanelGroupBoxStyle}" Header="メイン処理">
                                <Grid Margin="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"
                                               Text="背景許容色差" />
                                    <Slider Grid.Row="0"
                                            Grid.Column="1"
                                            Minimum="0"
                                            Maximum="1"
                                            TickFrequency="0.1"
                                            IsMoveToPointEnabled="True"
                                            Value="{Binding BackgroundTolerance}" />

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Margin="0,10,10,0"
                                               VerticalAlignment="Center"
                                               Text="輪郭設定方法" />
                                    <ComboBox Grid.Row="1"
                                              Grid.Column="1"
                                              Margin="0,10,0,0"
                                              ItemsSource="{Binding ContourSettingMethodOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedContourSettingMethod}" />

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Margin="0,10,10,0"
                                               VerticalAlignment="Center"
                                               Visibility="{Binding ContourToleranceVisibility}"
                                               Text="輪郭許容色差" />
                                    <Slider Grid.Row="2"
                                            Grid.Column="1"
                                            Margin="0,10,0,0"
                                            Minimum="0"
                                            Maximum="1"
                                            TickFrequency="0.1"
                                            IsMoveToPointEnabled="True"
                                            Visibility="{Binding ContourToleranceVisibility}"
                                            Value="{Binding ContourTolerance}" />

                                    <TextBlock Grid.Row="3"
                                               Grid.Column="0"
                                               Margin="0,10,10,0"
                                               VerticalAlignment="Center"
                                               Text="最大輪郭幅" />
                                    <Slider Grid.Row="3"
                                            Grid.Column="1"
                                            Margin="0,10,0,0"
                                            Minimum="0"
                                            Maximum="1"
                                            TickFrequency="0.1"
                                            IsMoveToPointEnabled="True"
                                            Value="{Binding MaxContourWidth}" />

                                    <TextBlock Grid.Row="4"
                                               Grid.Column="0"
                                               Margin="0,10,10,0"
                                               VerticalAlignment="Center"
                                               Text="ノイズ軽減" />
                                    <Slider Grid.Row="4"
                                            Grid.Column="1"
                                            Margin="0,10,0,0"
                                            Minimum="0"
                                            Maximum="1"
                                            TickFrequency="0.1"
                                            IsMoveToPointEnabled="True"
                                            Value="{Binding NoiseRemoval}" />

                                    <TextBlock Grid.Row="5"
                                               Grid.Column="0"
                                               Margin="0,10,10,0"
                                               VerticalAlignment="Center"
                                               Text="輪郭推測方法" />
                                    <ComboBox Grid.Row="5"
                                              Grid.Column="1"
                                              Margin="0,10,0,0"
                                              ItemsSource="{Binding ContourInferenceMethodOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedContourInferenceMethod}" />
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer Grid.Column="1"
                                  Margin="0,0,10,0"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="4">
                            <GroupBox Style="{StaticResource PanelGroupBoxStyle}" Header="後補正">
                                <Grid Margin="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"
                                               Text="透明部カット" />
                                    <Slider Grid.Row="0"
                                            Grid.Column="1"
                                            Minimum="0"
                                            Maximum="1"
                                            TickFrequency="0.1"
                                            IsMoveToPointEnabled="True"
                                            Value="{Binding TransparencyCut}" />

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Margin="0,10,10,0"
                                               VerticalAlignment="Center"
                                               Text="透明部切り上げ" />
                                    <Slider Grid.Row="1"
                                            Grid.Column="1"
                                            Margin="0,10,0,0"
                                            Minimum="0"
                                            Maximum="1"
                                            TickFrequency="0.1"
                                            IsMoveToPointEnabled="True"
                                            Value="{Binding OpaqueAlphaThreshold}" />

                                    <TextBlock Grid.Row="2"
                                               Grid.Column="0"
                                               Margin="0,10,10,0"
                                               VerticalAlignment="Center"
                                               Text="輪郭拡張" />
                                    <Slider Grid.Row="2"
                                            Grid.Column="1"
                                            Margin="0,10,0,0"
                                            Minimum="0"
                                            Maximum="1"
                                            TickFrequency="0.1"
                                            IsMoveToPointEnabled="True"
                                            Value="{Binding DespillExpansion}" />

                                    <TextBlock Grid.Row="3"
                                               Grid.Column="0"
                                               Margin="0,10,10,0"
                                               VerticalAlignment="Center"
                                               Text="輪郭補正強度" />
                                    <Slider Grid.Row="3"
                                            Grid.Column="1"
                                            Margin="0,10,0,0"
                                            Minimum="0"
                                            Maximum="1"
                                            TickFrequency="0.1"
                                            IsMoveToPointEnabled="True"
                                            Value="{Binding DespillMix}" />

                                    <TextBlock Grid.Row="4"
                                               Grid.Column="0"
                                               Margin="0,10,10,0"
                                               VerticalAlignment="Center"
                                               Text="輪郭明度補正" />
                                    <Slider Grid.Row="4"
                                            Grid.Column="1"
                                            Margin="0,10,0,0"
                                            Minimum="0"
                                            Maximum="1"
                                            TickFrequency="0.1"
                                            IsMoveToPointEnabled="True"
                                            Value="{Binding DespillBrightness}" />
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>

                    <ScrollViewer Grid.Column="2"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="4">
                            <GroupBox Style="{StaticResource PanelGroupBoxStyle}" Header="出力サイズ">
                                <Grid Margin="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"
                                               Text="リサイズ方式" />
                                    <ComboBox Grid.Row="0"
                                              Grid.Column="1"
                                              ItemsSource="{Binding ResizeInterpolationOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding SelectedResizeInterpolation}" />

                                    <TextBlock Grid.Row="1"
                                               Grid.Column="0"
                                               Margin="0,10,10,0"
                                               VerticalAlignment="Center"
                                               Text="出力サイズ" />
                                    <Grid Grid.Row="1"
                                          Grid.Column="1"
                                          Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center"
                                                   Text="倍率 (%)" />
                                        <TextBox Grid.Column="1"
                                                 Margin="0,0,12,0"
                                                 Text="{Binding ScalePercent, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource InputTextBoxStyle}" />
                                        <TextBlock Grid.Column="2"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center"
                                                   Text="幅" />
                                        <TextBox Grid.Column="3"
                                                 Margin="0,0,12,0"
                                                 Text="{Binding OutputWidth, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource InputTextBoxStyle}" />
                                        <TextBlock Grid.Column="4"
                                                   Margin="0,0,6,0"
                                                   VerticalAlignment="Center"
                                                   Text="高さ" />
                                        <TextBox Grid.Column="5"
                                                 Text="{Binding OutputHeight, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource InputTextBoxStyle}" />
                                    </Grid>
                                </Grid>
                            </GroupBox>

                            <GroupBox Style="{StaticResource PanelGroupBoxStyle}">
                                <GroupBox.Header>
                                    <DockPanel LastChildFill="False">
                                        <TextBlock VerticalAlignment="Center"
                                                   Text="縁取り" />
                                        <CheckBox Margin="10,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Foreground="#E8EEF5"
                                                  IsChecked="{Binding OutlineEnabled}" />
                                    </DockPanel>
                                </GroupBox.Header>
                                <Grid Margin="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0"
                                               Grid.Column="0"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"
                                               Text="色 / 太さ" />
                                    <Grid Grid.Row="0"
                                          Grid.Column="1"
                                          Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="12" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <DockPanel Grid.Column="0">
                                            <ToggleButton DockPanel.Dock="Right"
                                                          Margin="0,0,6,0"
                                                          IsChecked="{Binding IsOutlineColorEyedropperMode, Mode=OneWay}"
                                                          Click="OutlineEyedropperModeButton_OnClick">
                                                <Image Width="18" Height="18" Source="{x:Static services:ToolbarIconService.DropperIcon}" />
                                            </ToggleButton>
                                            <Button DockPanel.Dock="Right"
                                                    Click="OutlineColorPickerButton_OnClick">
                                                <Image Width="18" Height="18" Source="{x:Static services:ToolbarIconService.PaletteIcon}" />
                                            </Button>
                                            <Border DockPanel.Dock="Right"
                                                    Width="24"
                                                    Height="24"
                                                    Margin="0,0,6,0"
                                                    VerticalAlignment="Center"
                                                    CornerRadius="2"
                                                    BorderBrush="#5A6570"
                                                    BorderThickness="1"
                                                    Background="{Binding OutlineColorPreviewBrush}" />
                                            <TextBox Text="{Binding OutlineColorHex, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource InputTextBoxStyle}" />
                                        </DockPanel>

                                        <DockPanel Grid.Column="2"
                                                   LastChildFill="True">
                                            <TextBox DockPanel.Dock="Right"
                                                     Width="72"
                                                     Margin="10,0,0,0"
                                                     Text="{Binding OutlineThicknessText, Mode=OneWay}"
                                                     Style="{StaticResource InputTextBoxStyle}"
                                                     LostKeyboardFocus="OutlineThicknessTextBox_OnLostKeyboardFocus"
                                                     PreviewKeyDown="OutlineThicknessTextBox_OnPreviewKeyDown" />
                                            <Slider Minimum="0"
                                                    Maximum="100"
                                                    IsMoveToPointEnabled="True"
                                                    SmallChange="0.5"
                                                    LargeChange="2"
                                                    Value="{Binding OutlineThicknessSliderPosition}" />
                                        </DockPanel>
                                    </Grid>
                                </Grid>
                            </GroupBox>

                            <GroupBox Style="{StaticResource PanelGroupBoxStyle}" Header="バッチ処理">
                                <StackPanel Margin="8">
                                    <Border x:Name="BatchDropZone"
                                            AllowDrop="True"
                                            Padding="12"
                                            Background="#11161C"
                                            BorderBrush="#44515E"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            DragOver="BatchDropZone_OnDragOver"
                                            Drop="BatchDropZone_OnDrop">
                                        <StackPanel>
                                            <TextBlock Foreground="#E8EEF5"
                                                       FontWeight="SemiBold"
                                                       Text="複数画像をここへドロップ" />
                                            <TextBlock Margin="0,8,0,0"
                                                       Foreground="#D4DCE4"
                                                       Text="{Binding BatchStatusText}"
                                                       TextWrapping="Wrap" />
                                            <ProgressBar Margin="0,10,0,0"
                                                         Height="14"
                                                         Minimum="0"
                                                         Maximum="100"
                                                         Value="{Binding BatchProgressPercent, Mode=OneWay}" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Padding="12,8"
                Background="#151A20"
                BorderBrush="#2D3640"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Margin="0,0,10,0"
                            Width="14"
                            Height="14"
                            VerticalAlignment="Center"
                            Background="{Binding CoordinateStatusColorBrush}"
                            BorderBrush="#D4DCE4"
                            BorderThickness="1"
                            CornerRadius="2"
                            Visibility="{Binding CoordinateStatusColorVisibility}" />

                    <TextBlock Grid.Column="1"
                               VerticalAlignment="Center"
                               Text="{Binding CoordinateStatusText}"
                               TextWrapping="Wrap"
                               Foreground="#D4DCE4" />
                </Grid>

                <TextBlock Grid.Column="1"
                           Margin="16,0"
                           VerticalAlignment="Center"
                           Text="{Binding StatusText}"
                           TextWrapping="Wrap"
                           Foreground="#D4DCE4" />

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ProgressBar Grid.Column="0"
                                 Height="16"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding PreviewProgressPercent, Mode=OneWay}" />

                    <TextBlock Grid.Column="1"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#E8EEF5">
                        <Run Text="{Binding PreviewStageText, Mode=OneWay}" />
                        <Run Text=" " />
                        <Run Text="{Binding PreviewProgressPercent, Mode=OneWay, StringFormat={}{0:0}%}" />
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
