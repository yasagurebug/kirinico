<Window x:Class="Kirinico.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Kirinico.App.Controls"
        xmlns:services="clr-namespace:Kirinico.App.Services"
        Title="{Binding WindowTitle}"
        Width="1600"
        Height="980"
        MinWidth="1280"
        MinHeight="820"
        Background="#101316"
        AllowDrop="True"
        PreviewDragOver="Window_OnPreviewDragOver"
        PreviewDrop="Window_OnPreviewDrop"
        PreviewKeyDown="Window_OnPreviewKeyDown">
    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle"
               TargetType="Button">
            <Setter Property="Margin"
                    Value="0,0,8,0" />
            <Setter Property="Padding"
                    Value="10,6" />
            <Setter Property="Background"
                    Value="#1B222A" />
            <Setter Property="Foreground"
                    Value="#E8EEF5" />
            <Setter Property="BorderBrush"
                    Value="#36414C" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver"
                         Value="True">
                    <Setter Property="Foreground"
                            Value="#000000" />
                </Trigger>
                <Trigger Property="IsPressed"
                         Value="True">
                    <Setter Property="Foreground"
                            Value="#000000" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarToggleStyle"
               TargetType="ToggleButton">
            <Setter Property="Margin"
                    Value="0,0,8,0" />
            <Setter Property="Padding"
                    Value="10,6" />
            <Setter Property="Background"
                    Value="#1B222A" />
            <Setter Property="Foreground"
                    Value="#E8EEF5" />
            <Setter Property="BorderBrush"
                    Value="#36414C" />
            <Setter Property="BorderThickness"
                    Value="1" />
            <Style.Triggers>
                <Trigger Property="IsPressed"
                         Value="True">
                    <Setter Property="Foreground"
                            Value="#000000" />
                </Trigger>
                <Trigger Property="IsChecked"
                         Value="True">
                    <Setter Property="Background"
                            Value="#2B3F56" />
                    <Setter Property="BorderBrush"
                            Value="#79A4D8" />
                    <Setter Property="Foreground"
                            Value="#000000" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolbarComboBoxStyle"
               TargetType="ComboBox">
            <Setter Property="Margin"
                    Value="0,0,8,0" />
            <Setter Property="MinHeight"
                    Value="35" />
            <Setter Property="Padding"
                    Value="8,0" />
            <Setter Property="VerticalAlignment"
                    Value="Center" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Right" />
            <Setter Property="TextBox.TextAlignment"
                    Value="Right" />
            <Setter Property="FontSize"
                    Value="13" />
        </Style>

        <Style x:Key="InputTextBoxStyle"
               TargetType="TextBox">
            <Setter Property="TextAlignment"
                    Value="Right" />
            <Setter Property="HorizontalContentAlignment"
                    Value="Right" />
            <Setter Property="VerticalContentAlignment"
                    Value="Center" />
        </Style>

        <DataTemplate x:Key="ZoomPresetTemplate">
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding StringFormat={}{0}%}" />
        </DataTemplate>

    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="120" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="10"
                Margin="0,0,0,12"
                Background="#171C22"
                BorderBrush="#2D3640"
                BorderThickness="1"
                CornerRadius="10">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Margin="18,0,0,0"
                            Click="AboutButton_OnClick"
                            ToolTip="About">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="20"
                                   Height="20"
                                   VerticalAlignment="Center"
                                   Source="{x:Static services:ToolbarIconService.AboutIcon}" />
                            <TextBlock Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="About" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel DockPanel.Dock="Left"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Click="OpenImageButton_OnClick"
                            ToolTip="画像を開く (Ctrl+O)">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="20"
                                   Height="20"
                                   VerticalAlignment="Center"
                                   Source="{x:Static services:ToolbarIconService.FileOpenIcon}" />
                            <TextBlock Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="開く" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Click="SaveImageButton_OnClick"
                            ToolTip="PNG 保存 (Ctrl+S)">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="20"
                                   Height="20"
                                   VerticalAlignment="Center"
                                   Source="{x:Static services:ToolbarIconService.SaveIcon}" />
                            <TextBlock Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="保存" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Click="ReprocessButton_OnClick"
                            ToolTip="再処理 (Ctrl+R)">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="20"
                                   Height="20"
                                   VerticalAlignment="Center"
                                   Source="{x:Static services:ToolbarIconService.SyncIcon}" />
                            <TextBlock Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="再処理" />
                        </StackPanel>
                    </Button>

                    <CheckBox Margin="0,0,18,0"
                              VerticalAlignment="Center"
                              Foreground="#E8EEF5"
                              Content="自動再処理"
                              IsChecked="{Binding AutoReprocess}"
                              ToolTip="設定変更や手動指定のたびに自動再処理します。"
                              Tag="設定変更や手動指定のたびに自動再処理します。"
                              MouseEnter="SettingHelp_OnMouseEnter"
                              MouseLeave="SettingHelp_OnMouseLeave" />

                    <ComboBox x:Name="ZoomComboBox"
                              Style="{StaticResource ToolbarComboBoxStyle}"
                              Width="110"
                              Margin="0,0,18,0"
                              IsEditable="True"
                              IsTextSearchEnabled="False"
                              ItemsSource="{Binding ZoomPresetOptions}"
                              ItemTemplate="{StaticResource ZoomPresetTemplate}"
                              Text="{Binding ZoomPercentText, Mode=OneWay}"
                              SelectionChanged="ZoomComboBox_OnSelectionChanged"
                              LostKeyboardFocus="ZoomComboBox_OnLostKeyboardFocus"
                              PreviewKeyDown="ZoomComboBox_OnPreviewKeyDown" />

                    <ToggleButton Style="{StaticResource ToolbarToggleStyle}"
                                  IsChecked="{Binding IsHandMode, Mode=OneWay}"
                                  Click="HandModeButton_OnClick"
                                  ToolTip="ハンド">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="22"
                                   Height="22"
                                   Source="{x:Static services:ToolbarIconService.HandIcon}" />
                            <TextBlock Margin="6,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="移動" />
                        </StackPanel>
                    </ToggleButton>

                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Margin="18,0,8,0"
                            Click="ExportSettingsButton_OnClick"
                            ToolTip="現在の設定を JSON として書き出します。">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="20"
                                   Height="20"
                                   VerticalAlignment="Center"
                                   Source="{x:Static services:ToolbarIconService.ExportIcon}" />
                            <TextBlock Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="設定エクスポート" />
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource ToolbarButtonStyle}"
                            Click="ImportSettingsButton_OnClick"
                            ToolTip="JSON ファイルから設定を読み込みます。">
                        <StackPanel Orientation="Horizontal">
                            <Image Width="20"
                                   Height="20"
                                   VerticalAlignment="Center"
                                   Source="{x:Static services:ToolbarIconService.ImportIcon}" />
                            <TextBlock Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="設定インポート" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,0,0,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <controls:ZoomPanImageViewer Grid.Row="0"
                                         Grid.Column="0"
                                         Margin="0,0,6,6"
                                         Title="元画像"
                                         Source="{Binding OriginalImage}"
                                         OverlaySource="{Binding OriginalEditOverlayImage}"
                                         ViewerBackground="{Binding OriginalViewerBackground}"
                                         ViewportState="{Binding SharedViewport}"
                                         LeftPanEnabled="{Binding EditableViewerPansWithLeftButton}"
                                         InteractionCursor="{Binding EditableViewerCursor}"
                                         PointerPressed="OriginalViewer_OnPointerPressed"
                                         PointerMoved="OriginalViewer_OnPointerMoved"
                                         PointerReleased="OriginalViewer_OnPointerReleased"
                                         PointerExited="Viewer_OnPointerExited" />

            <controls:ZoomPanImageViewer Grid.Row="0"
                                         Grid.Column="1"
                                         Margin="6,0,0,6"
                                         Title="{Binding ResultViewerTitle}"
                                         Source="{Binding DisplayedResultImage}"
                                         ViewerBackground="{Binding FinalViewerBackground}"
                                         ViewportState="{Binding SharedViewport}"
                                         CoordinateScaleX="{Binding DisplayedResultCoordinateScaleX}"
                                         CoordinateScaleY="{Binding DisplayedResultCoordinateScaleY}"
                                         LeftPanEnabled="{Binding ResultViewerPansWithLeftButton}"
                                         InteractionCursor="{Binding ResultViewerCursor}"
                                         PointerPressed="FinalViewer_OnPointerPressed"
                                         PointerMoved="FinalViewer_OnPointerMoved"
                                         PointerExited="Viewer_OnPointerExited"
                                         ViewerDoubleClicked="FinalViewer_OnDoubleClicked"
                                         TitleClicked="ResultViewer_OnTitleClicked" />

            <Border Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,6,0,0"
                    Padding="12"
                    Background="#171C22"
                    BorderBrush="#2D3640"
                    BorderThickness="1"
                    CornerRadius="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1.5*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Grid.Column="0"
                                  Margin="0,0,8,0"
                                  Header="背景指定"
                                  Foreground="#E8EEF5">
                            <StackPanel Margin="8">
                                <TextBlock Text="指定モード"
                                           Tag="背景を手動seedで指定するか、色域指定で指定するかを選びます。"
                                           ToolTip="背景を手動seedで指定するか、色域指定で指定するかを選びます。"
                                           MouseEnter="SettingHelp_OnMouseEnter"
                                           MouseLeave="SettingHelp_OnMouseLeave" />
                                <ComboBox ItemsSource="{Binding BackgroundSpecificationModeOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedBackgroundSpecificationMode}"
                                          Tag="背景を手動seedで指定するか、色域指定で指定するかを選びます。"
                                          ToolTip="背景を手動seedで指定するか、色域指定で指定するかを選びます。"
                                          MouseEnter="SettingHelp_OnMouseEnter"
                                          MouseLeave="SettingHelp_OnMouseLeave" />
                                <TextBlock Margin="0,12,0,0"
                                           Text="背景色"
                                           Tag="色域指定モードの背景色です。"
                                           ToolTip="色域指定モードの背景色です。"
                                           MouseEnter="SettingHelp_OnMouseEnter"
                                           MouseLeave="SettingHelp_OnMouseLeave" />
                                <DockPanel Margin="0,0,0,8"
                                           IsEnabled="{Binding IsColorRangeBackgroundMode}">
                                    <ToggleButton DockPanel.Dock="Right"
                                                  Width="32"
                                                  Margin="0,0,6,0"
                                                  IsChecked="{Binding IsBackgroundColorEyedropperMode, Mode=OneWay}"
                                                  Click="BackgroundEyedropperModeButton_OnClick"
                                                  ToolTip="元画像または結果画像から背景色を取得">
                                        <Image Width="18"
                                               Height="18"
                                               Source="{x:Static services:ToolbarIconService.DropperIcon}" />
                                    </ToggleButton>
                                    <Button DockPanel.Dock="Right"
                                            Width="32"
                                            Click="BackgroundColorPickerButton_OnClick"
                                            ToolTip="背景色を選ぶ">
                                        <Image Width="18"
                                               Height="18"
                                               Source="{x:Static services:ToolbarIconService.PaletteIcon}" />
                                    </Button>
                                    <Border DockPanel.Dock="Right"
                                            Width="24"
                                            Height="24"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            CornerRadius="2"
                                            BorderBrush="#5A6570"
                                            BorderThickness="1"
                                            Background="{Binding BackgroundColorPreviewBrush}" />
                                    <TextBox Text="{Binding BackgroundColorHex, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputTextBoxStyle}"
                                             ToolTip="色域指定モードの背景色です。"
                                             Tag="色域指定モードの背景色です。"
                                             MouseEnter="SettingHelp_OnMouseEnter"
                                             MouseLeave="SettingHelp_OnMouseLeave" />
                                </DockPanel>

                                <TextBlock Margin="0,12,0,0"
                                           Text="seed"
                                           Tag="手動seedモードで背景 seed の追加と管理を行います。"
                                           ToolTip="手動seedモードで背景 seed の追加と管理を行います。"
                                           MouseEnter="SettingHelp_OnMouseEnter"
                                           MouseLeave="SettingHelp_OnMouseLeave" />
                                <StackPanel Margin="0,4,0,0"
                                            Orientation="Horizontal"
                                            IsEnabled="{Binding IsManualSeedBackgroundMode}">
                                    <ToggleButton Style="{StaticResource ToolbarToggleStyle}"
                                                  Margin="0,0,8,0"
                                                  IsChecked="{Binding IsWandAddMode, Mode=OneWay}"
                                                  Click="WandAddModeButton_OnClick"
                                                  ToolTip="背景 seed を追加">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Width="18"
                                                   Height="18"
                                                   Source="{x:Static services:ToolbarIconService.WandAddIcon}" />
                                            <TextBlock Margin="6,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Text="追加" />
                                        </StackPanel>
                                    </ToggleButton>

                                    <Button Style="{StaticResource ToolbarButtonStyle}"
                                            Margin="0"
                                            Click="WandRemoveModeButton_OnClick"
                                            ToolTip="背景 seed を削除">
                                        <StackPanel Orientation="Horizontal">
                                            <Image Width="18"
                                                   Height="18"
                                                   Source="{x:Static services:ToolbarIconService.WandRemoveIcon}" />
                                            <TextBlock Margin="6,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Text="削除" />
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Column="1"
                                  Margin="0,0,8,0"
                                  Header="処理強度"
                                  Foreground="#E8EEF5">
                            <StackPanel Margin="8">
                                <TextBlock Text="抜き"
                                           Tag="背景色にどこまで近いものを背景として含めるかです。0なら背景色と完全一致。"
                                           ToolTip="背景色にどこまで近いものを背景として含めるかです。0なら背景色と完全一致。"
                                           MouseEnter="SettingHelp_OnMouseEnter"
                                           MouseLeave="SettingHelp_OnMouseLeave" />
                                <Slider Minimum="0"
                                        Maximum="1"
                                        IsMoveToPointEnabled="True"
                                        SmallChange="0.01"
                                        LargeChange="0.05"
                                        Tag="背景色にどこまで近いものを背景として含めるかです。0なら背景色と完全一致。"
                                        ToolTip="背景色にどこまで近いものを背景として含めるかです。0なら背景色と完全一致。"
                                        MouseEnter="SettingHelp_OnMouseEnter"
                                        MouseLeave="SettingHelp_OnMouseLeave"
                                        Value="{Binding Extraction}" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="ノイズ除去"
                                           Tag="切り離された小さい前景成分をどこまで除去するかです。"
                                           ToolTip="切り離された小さい前景成分をどこまで除去するかです。"
                                           MouseEnter="SettingHelp_OnMouseEnter"
                                           MouseLeave="SettingHelp_OnMouseLeave" />
                                <Slider Minimum="0"
                                        Maximum="1"
                                        IsMoveToPointEnabled="True"
                                        SmallChange="0.01"
                                        LargeChange="0.05"
                                        Tag="切り離された小さい前景成分をどこまで除去するかです。"
                                        ToolTip="切り離された小さい前景成分をどこまで除去するかです。"
                                        MouseEnter="SettingHelp_OnMouseEnter"
                                        MouseLeave="SettingHelp_OnMouseLeave"
                                        Value="{Binding NoiseRemoval}" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="輪郭幅"
                                           Tag="最大何 px まで輪郭を削ってよいかです。"
                                           ToolTip="最大何 px まで輪郭を削ってよいかです。"
                                           MouseEnter="SettingHelp_OnMouseEnter"
                                           MouseLeave="SettingHelp_OnMouseLeave" />
                                <Slider Minimum="0"
                                        Maximum="10"
                                        IsMoveToPointEnabled="True"
                                        IsSnapToTickEnabled="True"
                                        TickFrequency="1"
                                        SmallChange="1"
                                        LargeChange="1"
                                        Tag="最大何 px まで輪郭を削ってよいかです。"
                                        ToolTip="最大何 px まで輪郭を削ってよいかです。"
                                        MouseEnter="SettingHelp_OnMouseEnter"
                                        MouseLeave="SettingHelp_OnMouseLeave"
                                        Value="{Binding ScanWidth}" />
                                <TextBlock Margin="0,10,0,0"
                                           Text="主線指定"
                                           Tag="代表的な主線色です。輪郭の色復元で参照します。"
                                           ToolTip="代表的な主線色です。輪郭の色復元で参照します。"
                                           MouseEnter="SettingHelp_OnMouseEnter"
                                           MouseLeave="SettingHelp_OnMouseLeave" />
                                <DockPanel Margin="0,0,0,8">
                                    <ToggleButton DockPanel.Dock="Right"
                                                  Width="32"
                                                  Margin="0,0,6,0"
                                                  IsChecked="{Binding IsLineColorEyedropperMode, Mode=OneWay}"
                                                  Click="LineEyedropperModeButton_OnClick"
                                                  ToolTip="元画像または結果画像から主線色を取得">
                                        <Image Width="18"
                                               Height="18"
                                               Source="{x:Static services:ToolbarIconService.DropperIcon}" />
                                    </ToggleButton>
                                    <Button DockPanel.Dock="Right"
                                            Width="32"
                                            Click="LineColorPickerButton_OnClick"
                                            ToolTip="主線色を選ぶ">
                                        <Image Width="18"
                                               Height="18"
                                               Source="{x:Static services:ToolbarIconService.PaletteIcon}" />
                                    </Button>
                                    <Border DockPanel.Dock="Right"
                                            Width="24"
                                            Height="24"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            CornerRadius="2"
                                            BorderBrush="#5A6570"
                                            BorderThickness="1"
                                            Background="{Binding LineColorPreviewBrush}" />
                                    <TextBox Text="{Binding LineColorHex, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputTextBoxStyle}"
                                             ToolTip="代表的な主線色です。輪郭の色復元で参照します。"
                                             Tag="代表的な主線色です。輪郭の色復元で参照します。"
                                             MouseEnter="SettingHelp_OnMouseEnter"
                                             MouseLeave="SettingHelp_OnMouseLeave" />
                                </DockPanel>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Column="2"
                                  Margin="0,0,8,0"
                                  Header="出力サイズ"
                                  Foreground="#E8EEF5">
                            <StackPanel Margin="8">
                                <TextBlock Text="リサイズ方式"
                                           Tag="出力リサイズ時の補間方式です。最近傍、線形、Cubic、Lanczos、Area から選べます。"
                                           ToolTip="出力リサイズ時の補間方式です。最近傍、線形、Cubic、Lanczos、Area から選べます。"
                                           MouseEnter="SettingHelp_OnMouseEnter"
                                           MouseLeave="SettingHelp_OnMouseLeave" />
                                <ComboBox ItemsSource="{Binding ResizeInterpolationOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding SelectedResizeInterpolation}"
                                          Margin="0,0,0,8"
                                          Tag="出力リサイズ時の補間方式です。最近傍、線形、Cubic、Lanczos、Area から選べます。"
                                          ToolTip="出力リサイズ時の補間方式です。最近傍、線形、Cubic、Lanczos、Area から選べます。"
                                          MouseEnter="SettingHelp_OnMouseEnter"
                                          MouseLeave="SettingHelp_OnMouseLeave" />
                                <TextBlock Text="倍率 (%)"
                                           Tag="倍率を変えると幅と高さも連動します。"
                                           MouseEnter="SettingHelp_OnMouseEnter"
                                           MouseLeave="SettingHelp_OnMouseLeave" />
                                <TextBox Text="{Binding ScalePercent, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         ToolTip="倍率を変えると幅と高さも連動します。"
                                          MouseEnter="SettingHelp_OnMouseEnter"
                                          MouseLeave="SettingHelp_OnMouseLeave"
                                         Tag="倍率を変えると幅と高さも連動します。"
                                         Margin="0,0,0,8" />
                                <TextBlock Text="幅"
                                           Tag="幅を変更すると高さと倍率が連動します。"
                                           ToolTip="幅を変更すると高さと倍率が連動します。"
                                           MouseEnter="SettingHelp_OnMouseEnter"
                                           MouseLeave="SettingHelp_OnMouseLeave" />
                                <TextBox Text="{Binding OutputWidth, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         ToolTip="幅を変更すると高さと倍率が連動します。"
                                          MouseEnter="SettingHelp_OnMouseEnter"
                                          MouseLeave="SettingHelp_OnMouseLeave"
                                         Tag="幅を変更すると高さと倍率が連動します。"
                                         Margin="0,0,0,8" />
                                <TextBlock Text="高さ"
                                           Tag="高さを変更すると幅と倍率が連動します。"
                                           ToolTip="高さを変更すると幅と倍率が連動します。"
                                           MouseEnter="SettingHelp_OnMouseEnter"
                                           MouseLeave="SettingHelp_OnMouseLeave" />
                                <TextBox Text="{Binding OutputHeight, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputTextBoxStyle}"
                                         ToolTip="高さを変更すると幅と倍率が連動します。"
                                          MouseEnter="SettingHelp_OnMouseEnter"
                                          MouseLeave="SettingHelp_OnMouseLeave"
                                         Tag="高さを変更すると幅と倍率が連動します。" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Grid.Column="3"
                                  Margin="0,0,8,0"
                                  Header="縁取り"
                                  Foreground="#E8EEF5">
                            <StackPanel Margin="8">
                                <CheckBox Content="縁取りを有効化"
                                          Foreground="#E8EEF5"
                                          IsChecked="{Binding OutlineEnabled}"
                                          Margin="0,0,0,8"
                                          ToolTip="最終 alpha に縁取りを付けます。"
                                          Tag="最終 alpha に縁取りを付けます。"
                                          MouseEnter="SettingHelp_OnMouseEnter"
                                          MouseLeave="SettingHelp_OnMouseLeave" />
                                <TextBlock Text="色"
                                           Tag="縁取り色です。"
                                           ToolTip="縁取り色です。"
                                           MouseEnter="SettingHelp_OnMouseEnter"
                                           MouseLeave="SettingHelp_OnMouseLeave" />
                                <DockPanel Margin="0,0,0,8">
                                    <ToggleButton DockPanel.Dock="Right"
                                                  Width="32"
                                                  Margin="0,0,6,0"
                                                  IsChecked="{Binding IsOutlineColorEyedropperMode, Mode=OneWay}"
                                                  Click="OutlineEyedropperModeButton_OnClick"
                                                  ToolTip="元画像または結果画像から縁取り色を取得">
                                        <Image Width="18"
                                               Height="18"
                                               Source="{x:Static services:ToolbarIconService.DropperIcon}" />
                                    </ToggleButton>
                                    <Button DockPanel.Dock="Right"
                                            Width="32"
                                            Click="OutlineColorPickerButton_OnClick"
                                            ToolTip="色を選ぶ">
                                        <Image Width="18"
                                               Height="18"
                                               Source="{x:Static services:ToolbarIconService.PaletteIcon}" />
                                    </Button>
                                    <Border DockPanel.Dock="Right"
                                            Width="24"
                                            Height="24"
                                            Margin="0,0,6,0"
                                            VerticalAlignment="Center"
                                            CornerRadius="2"
                                            BorderBrush="#5A6570"
                                            BorderThickness="1"
                                            Background="{Binding OutlineColorPreviewBrush}" />
                                    <TextBox Text="{Binding OutlineColorHex}"
                                             Style="{StaticResource InputTextBoxStyle}"
                                             ToolTip="縁取り色です。"
                                             Tag="縁取り色です。"
                                             MouseEnter="SettingHelp_OnMouseEnter"
                                             MouseLeave="SettingHelp_OnMouseLeave" />
                                </DockPanel>
                                <TextBlock Text="太さ"
                                           Tag="縁取りの太さです。"
                                           ToolTip="縁取りの太さです。"
                                           MouseEnter="SettingHelp_OnMouseEnter"
                                           MouseLeave="SettingHelp_OnMouseLeave" />
                                <DockPanel LastChildFill="True">
                                    <TextBox DockPanel.Dock="Right"
                                             Width="72"
                                             Margin="10,0,0,0"
                                             Text="{Binding OutlineThicknessText, Mode=OneWay}"
                                             Style="{StaticResource InputTextBoxStyle}"
                                             ToolTip="縁取りの太さです。"
                                             Tag="縁取りの太さです。"
                                             MouseEnter="SettingHelp_OnMouseEnter"
                                             MouseLeave="SettingHelp_OnMouseLeave"
                                             LostKeyboardFocus="OutlineThicknessTextBox_OnLostKeyboardFocus"
                                             PreviewKeyDown="OutlineThicknessTextBox_OnPreviewKeyDown" />
                                    <Slider Minimum="0"
                                            Maximum="100"
                                            IsMoveToPointEnabled="True"
                                            SmallChange="0.5"
                                            LargeChange="2"
                                            ToolTip="縁取りの太さです。"
                                            Tag="縁取りの太さです。"
                                            MouseEnter="SettingHelp_OnMouseEnter"
                                            MouseLeave="SettingHelp_OnMouseLeave"
                                            Value="{Binding OutlineThicknessSliderPosition}" />
                                </DockPanel>
                            </StackPanel>
                        </GroupBox>

                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                x:Name="BatchDropZone"
                AllowDrop="True"
                Padding="14"
                Margin="0,0,0,12"
                Background="#161B21"
                BorderBrush="#3A4652"
                BorderThickness="1"
                CornerRadius="10"
                DragOver="BatchDropZone_OnDragOver"
                Drop="BatchDropZone_OnDrop">
            <Grid ClipToBounds="True">
                <Border Background="#25323E"
                        Opacity="0.92"
                        CornerRadius="8"
                        RenderTransformOrigin="0,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform ScaleX="{Binding BatchProgressScale, Mode=OneWay}" />
                    </Border.RenderTransform>
                </Border>

                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock Text="バッチ"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="#E8EEF5" />
                    <TextBlock Text="{Binding BatchStatusText}"
                               Margin="0,12,0,0"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Foreground="#C6D2DE" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Padding="12,8"
                Background="#151A20"
                BorderBrush="#2D3640"
                BorderThickness="1"
                CornerRadius="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           Text="{Binding CoordinateStatusText}"
                           TextWrapping="Wrap"
                           Foreground="#D4DCE4" />

                <TextBlock Grid.Column="1"
                           Margin="16,0"
                           VerticalAlignment="Center"
                           Text="{Binding StatusText}"
                           TextWrapping="Wrap"
                           Foreground="#D4DCE4" />

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ProgressBar Grid.Column="0"
                                 Height="16"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding PreviewProgressPercent, Mode=OneWay}" />

                    <TextBlock Grid.Column="1"
                               Margin="12,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="#E8EEF5">
                        <Run Text="{Binding PreviewStageText, Mode=OneWay}" />
                        <Run Text=" " />
                        <Run Text="{Binding PreviewProgressPercent, Mode=OneWay, StringFormat={}{0:0}%}" />
                    </TextBlock>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
